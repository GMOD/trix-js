{
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "lib": ["es2019", "dom"],
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "sourceMap": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "esModuleInterop": true,
    "types": ["node"],
    "module": "nodenext"
  },
  "include": ["src"]
}
